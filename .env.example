# Symbol selection
SYMBOL_MODE=both
SYMBOLS=AAPL,MSFT,NVDA

# Scan behavior
SCAN_WINDOW_DEFAULT=1d
INTRADAY_LOOKBACK_DAYS=5
INTRADAY_BAR_SIZE=4 hours
# Weekend/replay testing:
# 0 = live mode (default), 1 = use SCAN_AS_OF_DATE for IBKR historical end datetime and Yahoo news as-of filtering
SCAN_TIME_TRAVEL=0
# Required when SCAN_TIME_TRAVEL=1. Format: YYYY-MM-DD (interpreted as 16:00 US/Eastern)
SCAN_AS_OF_DATE=
MIN_PCT_CHANGE=2.0
MAX_PCT_CHANGE=30.0
MIN_PRICE=3
MAX_PRICE=2000
# Leave volume empty to disable volume filtering.
# MIN_VOLUME is sent to IBKR scanner as aboveVolume and also validated locally.
# MAX_VOLUME is validated locally (IBKR scanner has no max-volume field).
# Volume is sourced from the latest IBKR daily TRADES bar for each symbol.
MIN_VOLUME=
MAX_VOLUME=
# 1 = send market-cap bounds to IBKR scanner (default), 0 = disable scanner cap bounds
# Cap bounds are scanner-only and are not applied to pure env symbols.
# symbols_snapshot.market_cap stays empty in scan snapshots.
MARKET_CAP=1
# Leave market cap empty to disable that scanner bound
MIN_MARKET_CAP=1000000000
MAX_MARKET_CAP=5000000000000

# News settings
NEWS_LOOKBACK_HOURS=24
MAX_NEWS_ARTICLES_PER_SYMBOL=8
YAHOO_RSS_REGION=US
YAHOO_RSS_LANG=en-US
NEWS_DEDUP_MODE=url
# Massive news provider toggle: 1=enabled (default), 0=disabled entirely.
MASSIVE_NEWS=1
# Optional Massive (Polygon) news source. Leave key empty to disable.
MASSIVE_API_KEY=
# Free-tier default pacing for Stocks Basic plan.
MASSIVE_MAX_CALLS_PER_MINUTE=5
# Safety cap per symbol to avoid excessive pagination.
MASSIVE_NEWS_MAX_PAGES_PER_SYMBOL=3

# OpenAI settings
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT_SECONDS=30
OPENAI_TEMPERATURE=0
# Hard cap for response tokens per article scoring request. Empty disables the cap.
OPENAI_MAX_COMPLETION_TOKENS=300
# Number of retries after the initial scoring attempt. 0 = no retries.
OPENAI_SCORE_RETRIES=1

# IBKR settings
# Paper: IB Gateway usually uses 4002, TWS usually uses 7497.
IBKR_HOST=127.0.0.1
IBKR_PORT=4002
IBKR_CLIENT_ID=37
IBKR_ACCOUNT_MODE=paper
# Per scan code (`TOP_PERC_GAIN` and `TOP_PERC_LOSE`), before de-duplication.
IBKR_MAX_SYMBOLS=100

# App settings
TIMEZONE=UTC
DB_PATH=./data/newstrade.db
CSV_EXPORT_DIR=./exports
LOG_LEVEL=INFO
