# API keys
## Required for `newstrade score`
OPENAI_API_KEY=
# Required for scan and optionally used for Massive news.
MASSIVE_API_KEY=

# OpenAI settings
## Model used for structured article scoring
OPENAI_MODEL=gpt-5-mini
OPENAI_TIMEOUT_SECONDS=20
OPENAI_TEMPERATURE=0
## Hard cap for response tokens per article scoring request. Empty disables the cap.
OPENAI_MAX_COMPLETION_TOKENS=1000
## Number of retries after the initial scoring attempt. 0 = no retries.
OPENAI_SCORE_RETRIES=1

# Free-tier default pacing for Stocks Basic plan.
MASSIVE_MAX_CALLS_PER_MINUTE=5
# Safety cap per symbol to avoid excessive pagination.
MASSIVE_NEWS_MAX_PAGES_PER_SYMBOL=3

# Scan behavior
## Weekend/replay testing:
## 0 = live mode (default), 1 = use SCAN_AS_OF_DATE and walk backward to the nearest completed US trading session
SCAN_TIME_TRAVEL=0
## Required when SCAN_TIME_TRAVEL=1. Format: YYYY-MM-DD
SCAN_AS_OF_DATE=

## Price change filters
MIN_PCT_CHANGE=4.0
MAX_PCT_CHANGE=80.0
MIN_PRICE=2
MAX_PRICE=2000
## Leave volume empty to disable volume filtering.
MIN_VOLUME=
MAX_VOLUME=

# News settings
## Massive news provider toggle: 1=enabled (default), 0=disabled entirely for news.
MASSIVE_NEWS=1

## Number of ranked movers that continue into news + scoring.
MAX_NEWS_SYMBOLS_PER_RUN=30
NEWS_LOOKBACK_HOURS=24
MAX_NEWS_ARTICLES_PER_SYMBOL=8
YAHOO_RSS_REGION=US
YAHOO_RSS_LANG=en-US

## Optional allowlist for Yahoo RSS article domains.
## Empty = accept all Yahoo RSS article URLs.
## Example: finance.yahoo.com,fool.com (recommended to only include finance.yahoo.com for relevance and reliability)
YAHOO_RSS_ALLOWED_DOMAINS=finance.yahoo.com

## Deduplication mode for news articles.
NEWS_DEDUP_MODE=url

# App settings
## App-level timezone setting. Stored timestamps remain UTC.
TIMEZONE=UTC
## SQLite database location
DB_PATH=./data/newstrade.db
## Directory used by `newstrade export`
CSV_EXPORT_DIR=./exports
LOG_LEVEL=INFO
